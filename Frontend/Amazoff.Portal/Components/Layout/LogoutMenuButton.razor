@inject Amazoff.Portal.Services.CurrentUserSession CurrentUserSession
@inject NavigationManager NavigationManager

<button type="button" class="dashboard-nav-item dashboard-nav-button" @onclick="OpenLogoutModal">
    <span>Logout</span>
</button>

@if (IsLogoutModalOpen)
{
    <div class="hr-modal-backdrop" @onclick="CloseLogoutModal">
        <div class="hr-modal hr-modal--confirm" @onclick:stopPropagation="true">
            <div class="hr-modal__header">
                <div>
                    <h3>Confirmar logout</h3>
                </div>

                <button type="button" class="hr-modal__close" @onclick="CloseLogoutModal">x</button>
            </div>

            <p class="dashboard-copy">Tem a certeza que deseja fazer logout?</p>

            <div class="hr-modal__actions">
                <button type="button" class="hr-secondary-button" @onclick="CloseLogoutModal">Cancelar</button>
                <button type="button" class="hr-secondary-button hr-secondary-button--danger" @onclick="ConfirmLogoutAsync">
                    Confirmar
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool IsLogoutModalOpen { get; set; }

    private void OpenLogoutModal()
    {
        IsLogoutModalOpen = true;
    }

    private void CloseLogoutModal()
    {
        IsLogoutModalOpen = false;
    }

    private async Task ConfirmLogoutAsync()
    {
        await CurrentUserSession.ClearAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
