@page "/"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject Amazoff.Portal.Services.CurrentUserSession CurrentUserSession

<PageTitle>Amazoff Portal</PageTitle>

<section class="login-shell min-h-screen bg-white text-slate-700">
    <div class="grid min-h-screen grid-cols-1 lg:grid-cols-[2fr_1fr]">
        <aside class="portal-image-panel relative hidden min-h-screen items-center overflow-hidden px-14 lg:flex xl:px-20">
            <div class="absolute inset-0 bg-slate-900/48"></div>
            <div class="absolute inset-0 bg-[#5aadf4]/10"></div>

            <div class="relative max-w-4xl">
                <p class="mb-6 text-sm font-bold uppercase tracking-[0.42em] text-white/80">Amazoff Portal</p>
                <h1 class="max-w-3xl text-5xl font-black uppercase leading-[1.15] tracking-wide text-white outline-none focus:outline-none xl:text-6xl">
                    Entre e saiba tudo sobre o seu negocio
                </h1>
            </div>
        </aside>

        <main class="flex min-h-screen items-center justify-center bg-white px-6 py-10 sm:px-10">
            <div class="w-full max-w-[380px]">
                <div class="mb-10 flex flex-col items-center text-center">
                    <img src="/images/Logo_Amazoff.png"
                         alt="Amazoff"
                         class="mb-8 h-auto w-56 object-contain" />

                    <h2 class="text-xl font-medium tracking-wide text-slate-500">
                        Entre na sua conta <span class="font-extrabold text-slate-600">AMAZOFF</span>
                    </h2>
                </div>

                <EditForm Model="LoginModel" OnValidSubmit="HandleLoginAsync">
                    <div class="space-y-5">
                        @if (CurrentStep == LoginStep.Username)
                        {
                            <div>
                                <label for="username" class="sr-only">Username</label>
                                <InputText id="username"
                                           @bind-Value="LoginModel.Username"
                                           autocomplete="username"
                                           placeholder="Username"
                                           disabled="@IsLoading"
                                           class="h-11 w-full rounded border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-600 outline-none transition placeholder:text-slate-500 focus:border-[#5aadf4] focus:ring-4 focus:ring-[#5aadf4]/15 disabled:cursor-not-allowed disabled:bg-slate-50 disabled:text-slate-400" />
                            </div>
                        }
                        else
                        {
                            <div>
                                <label for="password" class="sr-only">Password</label>
                                <InputText id="password"
                                           @bind-Value="LoginModel.Password"
                                           type="password"
                                           autocomplete="current-password"
                                           placeholder="Password"
                                           disabled="@IsLoading"
                                           class="h-11 w-full rounded border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-600 outline-none transition placeholder:text-slate-500 focus:border-[#5aadf4] focus:ring-4 focus:ring-[#5aadf4]/15 disabled:cursor-not-allowed disabled:bg-slate-50 disabled:text-slate-400" />

                                <button type="button"
                                        @onclick="BackToUsername"
                                        disabled="@IsLoading"
                                        class="mt-[5px] pl-[5px] text-sm font-semibold text-[#5aadf4] transition hover:text-[#439ce6] disabled:cursor-not-allowed disabled:text-slate-300">
                                    Alterar utilizador
                                </button>
                            </div>
                        }

                        <div class="flex justify-end">
                            <button type="submit"
                                    disabled="@IsLoading"
                                    class="h-10 min-w-28 rounded bg-[#5aadf4] px-7 text-sm font-bold text-white shadow-sm shadow-[#5aadf4]/20 transition hover:bg-[#439ce6] focus:outline-none focus:ring-4 focus:ring-[#5aadf4]/25 disabled:cursor-not-allowed disabled:bg-slate-300 disabled:shadow-none">
                                @ButtonText
                            </button>
                        </div>
                    </div>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <div class="@StatusClass">
                        @StatusMessage
                    </div>
                }
            </div>
        </main>
    </div>
</section>

@code {
    private PortalLogin LoginModel { get; } = new();
    private LoginStep CurrentStep { get; set; } = LoginStep.Username;
    private string? StatusMessage { get; set; }
    private bool IsError { get; set; }
    private bool IsLoading { get; set; }

    private string ButtonText => IsLoading
        ? "A verificar..."
        : CurrentStep == LoginStep.Username ? "Seguinte" : "Entrar";

    private string StatusClass =>
        $"mt-6 rounded border px-4 py-3 text-sm font-medium {(IsError ? "border-red-200 bg-red-50 text-red-600" : "border-[#5aadf4]/25 bg-[#5aadf4]/10 text-slate-600")}";

    private async Task HandleLoginAsync()
    {
        if (CurrentStep == LoginStep.Password && string.IsNullOrWhiteSpace(LoginModel.Password))
        {
            StatusMessage = "Indica a password.";
            IsError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(LoginModel.Username))
        {
            StatusMessage = "Indica o username.";
            IsError = true;
            return;
        }

        IsLoading = true;
        StatusMessage = null;
        IsError = false;

        try
        {
            var response = await TryValidateUserAsync(LoginModel.Username.Trim());

            if (response.IsSuccessStatusCode)
            {
                if (CurrentStep == LoginStep.Password)
                {
                    var loginResult = await response.Content.ReadFromJsonAsync<LoginResponse>();

                    if (loginResult?.User is not null)
                    {
                        await CurrentUserSession.SetAsync(new Amazoff.Portal.Services.CurrentUserDto(
                            loginResult.User.Id,
                            loginResult.User.Username,
                            loginResult.User.Email,
                            loginResult.User.RoleId,
                            loginResult.User.FirstName,
                            loginResult.User.LastName));
                    }

                    NavigationManager.NavigateTo("/dashboard");
                    return;
                }

                CurrentStep = LoginStep.Password;
                LoginModel.Password = null;
                return;
            }

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                StatusMessage = "Utilizador nao encontrado.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized && CurrentStep == LoginStep.Password)
            {
                StatusMessage = "Password incorreta.";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                StatusMessage = "Utilizador sem acesso.";
            }
            else
            {
                StatusMessage = "Nao foi possivel validar o utilizador.";
            }

            IsError = true;
        }
        catch (HttpRequestException)
        {
            StatusMessage = "Nao foi possivel ligar a API. Confirma que a API esta a correr.";
            IsError = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task<HttpResponseMessage> TryValidateUserAsync(string username)
    {
        var httpClient = HttpClientFactory.CreateClient("AmazoffApi");

        return await httpClient.PostAsJsonAsync(
            "/auth/login",
            new LoginRequest(username, CurrentStep == LoginStep.Password ? LoginModel.Password : null));
    }

    private void BackToUsername()
    {
        CurrentStep = LoginStep.Username;
        LoginModel.Password = null;
        StatusMessage = null;
        IsError = false;
    }

    private enum LoginStep
    {
        Username,
        Password
    }

    private sealed class PortalLogin
    {
        public string? Username { get; set; }
        public string? Password { get; set; }
    }

    private sealed record LoginRequest(string Username, string? Password);

    private sealed record LoginResponse(bool Success, string Message, LoginUserResponse? User);

    private sealed record LoginUserResponse(
        int Id,
        string Username,
        string Email,
        int? RoleId,
        string FirstName,
        string LastName);
}
